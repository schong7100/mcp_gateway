# MCP Gateway Environment Configuration

# Database
MCP_GATEWAY_DATABASE_URL=postgresql+asyncpg://mcp:mcp@postgres:5432/mcp_gateway
POSTGRES_USER=mcp
POSTGRES_PASSWORD=mcp
POSTGRES_DB=mcp_gateway

# Upstream APIs
MCP_GATEWAY_CONTEXT7_BASE_URL=https://context7.com/api
MCP_GATEWAY_EXA_BASE_URL=https://api.exa.ai
MCP_GATEWAY_EXA_API_KEY=your-exa-api-key-here

# Proxy API Key (for MCP stdio servers that can't send JWT)
MCP_GATEWAY_PROXY_API_KEY=727a17912b5c1b79564ba42e59b47ae17dc65c82df35717adb14e75d0bb27b0b

# Keycloak
MCP_GATEWAY_KEYCLOAK_URL=http://10.1.10.188:18080
MCP_GATEWAY_KEYCLOAK_REALM=mcp-gateway
MCP_GATEWAY_KEYCLOAK_CLIENT_ID=mcp-gateway-api
MCP_GATEWAY_KEYCLOAK_ADMIN_CLIENT_ID=mcp-gateway-admin
MCP_GATEWAY_KEYCLOAK_ADMIN_CLIENT_SECRET=mcp-gateway-admin-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Proxy (if behind corporate proxy)
# MCP_GATEWAY_HTTP_PROXY=http://proxy.corp.example:8080
# MCP_GATEWAY_HTTPS_PROXY=http://proxy.corp.example:8080

# Content Filter
MCP_GATEWAY_FILTER_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:18080
NEXT_PUBLIC_KEYCLOAK_REALM=mcp-gateway
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=mcp-gateway-web
# Dev mode: skip Keycloak login, use mock admin user (local testing only)
NEXT_PUBLIC_DEV_MODE=false
