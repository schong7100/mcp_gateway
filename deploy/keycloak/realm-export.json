{
  "realm": "mcp-gateway",
  "enabled": true,
  "displayName": "MCP Gateway",
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "MCP Gateway 관리자 — 전체 기능 접근",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "viewer",
        "description": "MCP Gateway 조회자 — 로그/감사 읽기 전용",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {}
  },
  "clients": [
    {
      "clientId": "mcp-gateway-api",
      "name": "MCP Gateway API (Backend)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "mcp-gateway-api-secret",
      "protocolMappers": [
        {
          "name": "audience-mcp-gateway-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mcp-gateway-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "mcp-gateway-web",
      "name": "MCP Gateway Web (Frontend)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:3000"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-mcp-gateway-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "mcp-gateway-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "mcp-gateway-admin",
      "name": "MCP Gateway Admin Client (Backend service account)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "secret": "mcp-gateway-admin-secret"
    }
  ],
  "users": [
    {
      "username": "admin-user",
      "enabled": true,
      "email": "admin@mcp-gateway.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "viewer-user",
      "enabled": true,
      "email": "viewer@mcp-gateway.local",
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
